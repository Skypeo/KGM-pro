---
import { ZONES } from "../data/site";
import Marquee from "./Marquee.astro";

const zoneNames = ZONES.map((z) => z.name);
---

<section id="zones" class="bg-mauve-900 text-cream-50 py-24 lg:py-32 grain">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="grid gap-16 lg:grid-cols-12 lg:gap-20">
      <div class="lg:col-span-5 reveal">
        <p class="text-xs uppercase tracking-[0.22em] text-mauve-300">Zones d'intervention</p>
        <h2 class="mt-6 font-display text-4xl leading-tight sm:text-5xl">
          Sur tout le
          <br />
          <span class="script text-7xl text-mauve-200">Grand Nancy</span>
          <br />
          et au-delà.
        </h2>
        <p class="mt-8 max-w-md text-sm leading-relaxed text-cream-100/80">
          Treize communes couvertes au quotidien. En dehors de cette zone ? Un coup de fil suffit
          pour évaluer un déplacement.
        </p>
      </div>

      <div class="lg:col-span-7 reveal" style="--reveal-delay: 150ms;">
        <ul class="grid grid-cols-2 gap-x-8 gap-y-2 sm:grid-cols-3">
          {ZONES.map((z) => (
            <li>
              <a
                href={`/zones/${z.slug}`}
                class="group flex items-baseline justify-between border-b border-mauve-700/40 py-3 transition hover:border-mauve-300"
              >
                <span class="font-display text-lg text-cream-50 transition group-hover:text-mauve-200">
                  {z.name}
                </span>
                {z.postalCode && (
                  <span class="text-xs text-cream-100/50">{z.postalCode}</span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Marquee ticker des communes -->
  <div class="mt-20 border-t border-mauve-700/30 pt-8 pb-2 font-display text-2xl text-mauve-200/60 sm:text-3xl">
    <Marquee items={zoneNames} speed={50} />
  </div>
</section>
