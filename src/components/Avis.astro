---
const avis = [
  {
    initiales: "CB",
    nom: "Christian Baudin",
    categorie: "Façade extérieure",
    texte:
      "J'ai fait peindre ma façade par Gary. Très satisfait : travail sérieux, professionnel, s'adapte à nos desiderata. Je recommande vivement.",
  },
  {
    initiales: "AU",
    nom: "Aurélie Uhrig",
    categorie: "Plafond + façade",
    texte:
      "Plafond intérieur suite incendie + façade extérieure. Très professionnel, soigné, propre. Vous pouvez y aller les yeux fermés !",
  },
  {
    initiales: "CM",
    nom: "Christophe Marin",
    categorie: "Rénovation complète",
    texte:
      "J'ai confié la rénovation complète de mon appartement à Gary. Je ne peux que recommander : il s'est occupé de tout, de la plomberie à la finition.",
  },
  {
    initiales: "SP",
    nom: "Sandrine Ph",
    categorie: "Peinture sablée",
    texte:
      "Rénovation d'une montée d'escaliers en peinture sablée. Très bon résultat, travail soigné, chantier rendu propre, bonne communication avec l'artisan.",
  },
];

// TODO : remplacer par le vrai lien Google My Business quand le client le fournit
const googleReviewsUrl = "#";
---

<section id="avis" class="crepi relative py-20 sm:py-24 lg:py-28">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <!-- Header -->
    <div class="mx-auto max-w-3xl text-center">
      <p class="inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.28em] text-mauve-600">
        <span class="h-px w-8 bg-mauve-300"></span>
        Témoignages
        <span class="h-px w-8 bg-mauve-300"></span>
      </p>
      <h2 class="mt-6 font-display text-3xl leading-[1.2] text-ink-900 sm:text-4xl lg:text-5xl">
        5,0 / 5 sur Google.
        <br class="hidden sm:block" />
        Et chaque avis cite Gary <span class="script-gradient italic">par son prénom</span>.
      </h2>
    </div>

    <!-- Carte Google centrale -->
    <div class="mx-auto mt-14 max-w-xl sm:mt-16">
      <article class="rounded-2xl bg-cream-50 p-8 ring-1 ring-mauve-200/60 shadow-xl shadow-mauve-950/[0.06] sm:p-10">
        <!-- Logo + label -->
        <div class="flex items-center justify-center gap-2.5">
          <svg viewBox="0 0 24 24" class="h-6 w-6" aria-hidden="true">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.75h3.57c2.08-1.92 3.28-4.74 3.28-8.07z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.75c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.12A6.6 6.6 0 0 1 5.5 12c0-.74.13-1.45.34-2.12V7.04H2.18A11 11 0 0 0 1 12c0 1.78.43 3.46 1.18 4.96l3.66-2.84z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.04l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38z"/>
          </svg>
          <span class="text-sm font-medium text-ink-900">Avis Google</span>
        </div>

        <!-- Note -->
        <div class="mt-5 flex items-baseline justify-center gap-1.5">
          <span class="font-display text-6xl leading-none text-ink-900 sm:text-7xl">5,0</span>
          <span class="text-xl text-mauve-400">/ 5</span>
        </div>

        <!-- Étoiles -->
        <div class="mt-4 flex justify-center gap-1">
          {Array.from({ length: 5 }).map(() => (
            <svg viewBox="0 0 24 24" fill="#F5A623" class="h-5 w-5">
              <path d="M12 2l2.9 6.9 7.1.6-5.4 4.7 1.7 7-6.3-3.8-6.3 3.8 1.7-7L2 9.5l7.1-.6L12 2z"/>
            </svg>
          ))}
        </div>

        <p class="mt-5 text-center text-sm text-ink-700/70">
          Basé sur plus de 25 avis vérifiés
        </p>

        <!-- Badge vérifié -->
        <div class="mt-4 flex justify-center">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-mauve-100 px-3 py-1 text-[12px] text-mauve-700 ring-1 ring-mauve-200">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3 w-3">
              <polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Avis vérifiés
          </span>
        </div>

        <!-- CTA -->
        <a
          href={googleReviewsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-7 flex w-full items-center justify-center gap-2 rounded-full bg-mauve-500 px-6 py-3.5 text-sm font-medium text-cream-50 shadow-lg shadow-mauve-950/20 transition hover:bg-mauve-400 hover:shadow-xl"
        >
          Voir tous les avis sur Google
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-4 w-4">
            <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/>
            <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </article>
    </div>

    <!-- Grille des 4 témoignages -->
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:mt-14 lg:grid-cols-4">
      {avis.map((a) => (
        <figure class="flex flex-col rounded-xl bg-cream-50 p-6 ring-1 ring-mauve-200/50 transition hover:ring-mauve-300/70">
          <!-- En-tête : avatar + nom -->
          <header class="flex items-center gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-mauve-500 text-[12px] font-medium tracking-wide text-cream-50">
              {a.initiales}
            </div>
            <div class="min-w-0">
              <p class="truncate text-sm font-medium text-ink-900">{a.nom}</p>
              <p class="mt-0.5 flex items-center gap-1 text-[11px] text-ink-700/60">
                <svg viewBox="0 0 24 24" class="h-2.5 w-2.5 shrink-0" aria-hidden="true">
                  <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.75h3.57c2.08-1.92 3.28-4.74 3.28-8.07z"/>
                  <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.75c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23z"/>
                  <path fill="#FBBC05" d="M5.84 14.12A6.6 6.6 0 0 1 5.5 12c0-.74.13-1.45.34-2.12V7.04H2.18A11 11 0 0 0 1 12c0 1.78.43 3.46 1.18 4.96l3.66-2.84z"/>
                  <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.04l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38z"/>
                </svg>
                Avis Google
              </p>
            </div>
          </header>

          <!-- Étoiles -->
          <div class="mt-5 flex gap-0.5">
            {Array.from({ length: 5 }).map(() => (
              <svg viewBox="0 0 24 24" fill="#F5A623" class="h-3.5 w-3.5">
                <path d="M12 2l2.9 6.9 7.1.6-5.4 4.7 1.7 7-6.3-3.8-6.3 3.8 1.7-7L2 9.5l7.1-.6L12 2z"/>
              </svg>
            ))}
          </div>

          <!-- Catégorie -->
          <p class="mt-4 text-[11px] uppercase tracking-[0.18em] text-mauve-600">
            {a.categorie}
          </p>

          <!-- Citation -->
          <blockquote class="mt-3 text-sm leading-relaxed text-ink-700/85">
            «&nbsp;{a.texte}&nbsp;»
          </blockquote>
        </figure>
      ))}
    </div>
  </div>
</section>
