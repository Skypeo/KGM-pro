---
import { SITE } from "../data/site";
---

<section id="devis" class="crepi relative bg-cream-100 py-24 lg:py-32">
  <div class="mx-auto max-w-5xl px-6 text-center lg:px-10 reveal">
    <p class="text-xs uppercase tracking-[0.22em] text-mauve-600">Le devis</p>
    <h2 class="mt-6 font-display text-4xl leading-tight text-ink-900 sm:text-5xl lg:text-6xl">
      Un projet en tête ?
      <br />
      Un <span class="script text-7xl text-mauve-500">devis sur-mesure</span>,
      <br />
      étudié à la main.
    </h2>

    <p class="mx-auto mt-8 max-w-2xl text-base leading-relaxed text-ink-700">
      Chaque devis est préparé à la main, jamais à la louche. Gary prend le temps d'évaluer chaque
      surface, chaque difficulté, chaque exigence — c'est ce qui permet d'aligner précisément le
      prix sur la prestation.
    </p>

    <div class="mt-12 flex flex-wrap items-center justify-center gap-4">
      <a
        href={`tel:${SITE.phoneRaw}`}
        class="inline-flex items-center gap-2 rounded-full bg-mauve-500 px-7 py-4 text-sm font-medium text-cream-50 shadow-lg shadow-mauve-500/20 transition hover:bg-mauve-600"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-4 w-4">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.12.93.34 1.84.65 2.72a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.36-1.36a2 2 0 012.11-.45c.88.31 1.79.53 2.72.65A2 2 0 0122 16.92z" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Appeler {SITE.phone}
      </a>
      <a
        href={`mailto:${SITE.email}?subject=Demande de devis`}
        class="inline-flex items-center gap-2 rounded-full border border-mauve-400 px-7 py-4 text-sm text-mauve-700 transition hover:bg-mauve-50"
      >
        Écrire à Gary
      </a>
    </div>

    <p class="mt-10 text-xs uppercase tracking-[0.22em] text-mauve-700/70">
      Devis gratuit · Tarification sur-mesure · Étudié à la main
    </p>
  </div>
</section>
