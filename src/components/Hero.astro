---
import { Image } from "astro:assets";
import moulure from "../assets/moulure-cherubin.webp";
import { SITE, ZONES } from "../data/site";

// Toutes les zones jointes en une seule string, séparées par un point médian.
// Servies en double dans le marquee pour boucle continue invisible.
const zonesText = ZONES.map((z) => z.name).join(" · ");
---

<section class="relative isolate min-h-[100dvh] overflow-hidden bg-mauve-900 text-white grain">
  <!-- Background photo -->
  <Image
    src={moulure}
    alt=""
    loading="eager"
    fetchpriority="high"
    widths={[800, 1280, 1920, 2560]}
    sizes="100vw"
    class="hero-bg-img absolute inset-0 -z-20 h-full w-full object-cover object-center"
  />

  <!-- Mauve overlay -->
  <div
    class="absolute inset-0 -z-10"
    style="background: linear-gradient(180deg, rgba(42,31,61,0.55) 0%, rgba(122,107,154,0.55) 45%, rgba(42,31,61,0.85) 100%);"
  ></div>

  <!-- Subtle warm light from right -->
  <div
    class="absolute inset-y-0 right-0 -z-10 w-2/3"
    style="background: radial-gradient(ellipse at 80% 30%, rgba(235, 215, 180, 0.18), transparent 60%);"
  ></div>

  <!-- Hero content -->
  <div class="relative flex min-h-[100dvh] flex-col px-6 pt-32 pb-10 lg:px-10 lg:pt-40 lg:pb-14">
    <div class="mx-auto flex w-full max-w-7xl flex-1 flex-col justify-end">
      <div class="max-w-3xl reveal">
        <h1 class="hero-readable font-display text-[2.75rem] leading-[1.05] tracking-tight text-white sm:text-6xl lg:text-7xl">
          Peintre, plâtrier
          <br />
          et <span class="script-gradient italic">décorateur</span> à Nancy.
        </h1>

        <p class="mt-8 max-w-xl text-base leading-relaxed text-cream-100/85 sm:text-lg" style="--reveal-delay: 200ms;">
          Vingt ans de métier. Double CAP &amp; BP mention décorateur, intervenant au CFA de Pont-à-Mousson. Quatre spécialités décoratives rares en Lorraine : faux bois, faux marbre, faux ciel et feuille d'or.
        </p>

        <div class="mt-10 flex flex-wrap items-center gap-4" style="--reveal-delay: 400ms;">
          <a
            href="#devis"
            class="inline-flex items-center gap-2 rounded-full bg-mauve-500 px-6 py-3.5 text-sm font-medium text-cream-50 shadow-lg shadow-mauve-950/30 transition hover:bg-mauve-400 hover:shadow-xl"
          >
            Demande de devis gratuit
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-4 w-4">
              <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/>
              <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href={`tel:${SITE.phoneRaw}`}
            class="text-sm text-cream-100/90 underline-offset-4 transition hover:underline"
          >
            ou appeler {SITE.phone}
          </a>
        </div>
      </div>

      <!-- Hero footer band -->
      {/* TODO Gary : réactiver bloc avis Google quand le lien et le compteur sont validés */}
      <div class="mt-16 flex flex-col gap-4 border-t border-cream-100/15 pt-6 text-xs text-cream-100/75 sm:flex-row sm:items-center sm:gap-6 sm:text-sm">
        <div class="flex shrink-0 items-center gap-2 tracking-wide">
          <span class="h-1 w-1 rounded-full bg-cream-100/50"></span>
          {SITE.responseTime}
        </div>

        <!-- Marquee : toutes les zones d'intervention défilent en continu, droite → gauche -->
        <div class="flex w-full items-center gap-3 sm:flex-1 sm:min-w-0">
          <span class="shrink-0 text-[11px] uppercase tracking-[0.18em] text-cream-100/40">
            Intervention
          </span>
          <span class="hidden h-px w-6 shrink-0 bg-cream-100/20 sm:block"></span>
          <div class="zones-marquee relative w-full overflow-hidden">
            <div class="zones-marquee__track flex whitespace-nowrap text-cream-100/65">
              <span class="pr-6">{zonesText}</span>
              <span class="pr-6">·</span>
              <span class="pr-6" aria-hidden="true">{zonesText}</span>
              <span class="pr-6" aria-hidden="true">·</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .zones-marquee {
    /* Fade doux aux deux bords pour que le texte ne se coupe pas brutalement */
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0,
      black 6%,
      black 94%,
      transparent 100%
    );
    mask-image: linear-gradient(
      90deg,
      transparent 0,
      black 6%,
      black 94%,
      transparent 100%
    );
  }

  .zones-marquee__track {
    /* Le contenu est dupliqué : on translate de -50% pour que la 2e copie
       prenne exactement la place de la 1re → boucle invisible. */
    width: max-content;
    animation: zones-marquee-flow 38s linear infinite;
  }

  @keyframes zones-marquee-flow {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .zones-marquee__track {
      animation: none;
    }
  }
</style>
