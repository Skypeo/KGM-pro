---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../data/site";
---

<BaseLayout
  title="Mentions légales"
  description="Mentions légales de KGM Pro Decor — Gary Goder, artisan peintre / plâtrier en Lorraine."
  noindex={true}
  lightHeader={false}
>
  <section class="bg-cream-50 pt-40 pb-24 lg:pt-48 lg:pb-32">
    <div class="mx-auto max-w-3xl px-6 lg:px-10">
      <p class="text-xs uppercase tracking-[0.22em] text-mauve-600">Mentions</p>
      <h1 class="mt-6 font-display text-4xl leading-tight text-ink-900 sm:text-5xl">
        Mentions <span class="script text-6xl text-mauve-500">légales</span>.
      </h1>

      <div class="mt-12 space-y-10 text-base leading-relaxed text-ink-700">
        <div>
          <h2 class="font-display text-2xl text-ink-900">Éditeur du site</h2>
          <p class="mt-3">
            {SITE.name}<br />
            Gary Goder, artisan<br />
            SIRET : <span class="text-mauve-600">à compléter</span><br />
            Adresse : <span class="text-mauve-600">à compléter</span><br />
            Téléphone : {SITE.phone}<br />
            Email : {SITE.email}
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl text-ink-900">Directeur de la publication</h2>
          <p class="mt-3">Gary Goder</p>
        </div>

        <div>
          <h2 class="font-display text-2xl text-ink-900">Hébergement</h2>
          <p class="mt-3">
            <span class="text-mauve-600">À compléter selon l'hébergeur retenu (Netlify, Vercel, OVH...)</span>
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl text-ink-900">Propriété intellectuelle</h2>
          <p class="mt-3">
            L'ensemble du contenu de ce site (textes, images, identité visuelle) est la propriété de {SITE.name}.
            Toute reproduction, totale ou partielle, est soumise à autorisation écrite préalable.
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl text-ink-900">Données personnelles</h2>
          <p class="mt-3">
            Voir la <a href="/politique-confidentialite" class="text-mauve-600 underline-offset-4 hover:underline">politique de confidentialité</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
