---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE, ZONES, SERVICES } from "../data/site";
import heroContact from "../assets/realisations/moulure/moulure-01.webp";

const seoTitle = "Contact";
const seoDesc = `Contactez Gary Goder pour un devis gratuit sur-mesure. Peintre, plâtrier et décorateur en Lorraine, intervention à Nancy et alentours.`;

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  url: `${SITE.url}/contact`,
  name: "Contact KGM Pro Decor",
  description: seoDesc,
  mainEntity: { "@id": `${SITE.url}/#localbusiness` },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: SITE.url },
    { "@type": "ListItem", position: 2, name: "Contact", item: `${SITE.url}/contact` },
  ],
};
---

<BaseLayout title={seoTitle} description={seoDesc} extraSchemas={[contactPageSchema, breadcrumbSchema]}>
  <!-- HERO Contact -->
  <section class="relative isolate overflow-hidden bg-mauve-900 text-cream-50 pt-40 pb-24 lg:pt-48 lg:pb-32 grain">
    <Image
      src={heroContact}
      alt=""
      loading="eager"
      widths={[800, 1280, 1920]}
      sizes="100vw"
      class="hero-bg-img absolute inset-0 -z-20 h-full w-full object-cover object-center"
    />
    <div class="absolute inset-0 -z-10 hero-overlay-image"></div>

    <div class="mx-auto max-w-7xl px-6 lg:px-10">
      <nav class="mb-10" aria-label="Fil d'Ariane">
        <ol class="flex flex-wrap items-center text-xs uppercase tracking-[0.22em] text-cream-100/60">
          <li><a href="/" class="hover:text-cream-50">Accueil</a></li>
          <li aria-hidden="true" class="mx-2">/</li>
          <li><span class="text-cream-100" aria-current="page">Contact</span></li>
        </ol>
      </nav>

      <p class="text-xs uppercase tracking-[0.22em] text-mauve-300">Contact</p>
      <h1 class="hero-readable mt-6 max-w-3xl font-display text-5xl leading-[1.05] sm:text-6xl lg:text-7xl">
        <span class="script-gradient italic text-[1.4em]">Devis gratuit</span>
        pour votre projet.
      </h1>
      <p class="mt-10 max-w-2xl text-lg leading-relaxed text-cream-100/85">
        Chaque devis est étudié et chiffré personnellement par Gary. Téléphone, email ou formulaire — au choix. Réponse honnête à chaque demande.
      </p>
    </div>
  </section>

  <!-- COORDONNÉES + FORMULAIRE -->
  <section class="crepi relative bg-cream-50 py-24 lg:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-10">
      <div class="grid gap-16 lg:grid-cols-12 lg:gap-20">
        <!-- Coordonnées -->
        <div class="lg:col-span-5">
          <p class="text-xs uppercase tracking-[0.22em] text-mauve-600">Coordonnées</p>
          <h2 class="mt-6 font-display text-3xl leading-tight text-ink-900 sm:text-4xl">
            Un coup de fil
            <br />
            <span class="script-gradient italic">suffit</span>.
          </h2>

          <div class="mt-10 space-y-8">
            <!-- Téléphone -->
            <a
              href={`tel:${SITE.phoneRaw}`}
              class="group flex items-start gap-5 rounded-2xl bg-cream-100 p-6 transition hover:bg-mauve-50"
            >
              <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-mauve-500 text-cream-50">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-5 w-5">
                  <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.12.93.34 1.84.65 2.72a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.36-1.36a2 2 0 012.11-.45c.88.31 1.79.53 2.72.65A2 2 0 0122 16.92z" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <p class="text-[11px] uppercase tracking-[0.22em] text-mauve-700/70">Téléphone</p>
                <p class="mt-1 font-display text-2xl text-ink-900 transition group-hover:text-mauve-600">{SITE.phone}</p>
                <p class="mt-2 text-sm text-ink-700/80">Le moyen le plus direct pour parler du projet.</p>
              </div>
            </a>

            <!-- Email -->
            <a
              href={`mailto:${SITE.email}?subject=Demande de devis`}
              class="group flex items-start gap-5 rounded-2xl bg-cream-100 p-6 transition hover:bg-mauve-50"
            >
              <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-mauve-500 text-cream-50">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-5 w-5">
                  <rect x="3" y="5" width="18" height="14" rx="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <polyline points="3 7 12 13 21 7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <p class="text-[11px] uppercase tracking-[0.22em] text-mauve-700/70">Email</p>
                <p class="mt-1 font-display text-xl text-ink-900 transition group-hover:text-mauve-600 break-all">{SITE.email}</p>
                <p class="mt-2 text-sm text-ink-700/80">Pour les demandes détaillées avec photos.</p>
              </div>
            </a>

            <!-- Zone -->
            <div class="flex items-start gap-5 rounded-2xl bg-cream-100 p-6">
              <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-mauve-500 text-cream-50">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-5 w-5">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="12" cy="10" r="3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <p class="text-[11px] uppercase tracking-[0.22em] text-mauve-700/70">Intervention</p>
                <p class="mt-1 font-display text-xl text-ink-900">Nancy & Grand Nancy</p>
                <p class="mt-2 text-sm text-ink-700/80">{ZONES.length} communes couvertes — <a href="/zones" class="text-mauve-600 underline-offset-4 hover:underline">voir la liste</a>.</p>
              </div>
            </div>
          </div>

          {/* TODO Gary : ajouter ici horaires, adresse, plan Google Maps une fois confirmés */}
        </div>

        <!-- Formulaire -->
        <div class="lg:col-span-7">
          <p class="text-xs uppercase tracking-[0.22em] text-mauve-600">Demande de devis</p>
          <h2 class="mt-6 font-display text-3xl leading-tight text-ink-900 sm:text-4xl">
            Décrire le <span class="script-gradient italic">projet</span>.
          </h2>
          <p class="mt-6 max-w-md text-sm leading-relaxed text-ink-700/80">
            Plus la description est précise, plus le devis sera juste. Indiquez les surfaces,
            les pièces, l'état actuel, et joignez des photos par email si possible.
          </p>

          {/* TODO Gary : connecter ce formulaire à un service (Formspree / Netlify Forms / API).
              Pour l'instant, le bouton "Envoyer" ouvre le mail par défaut avec les infos pré-remplies. */}
          <form
            action={`mailto:${SITE.email}`}
            method="post"
            enctype="text/plain"
            class="mt-10 space-y-5"
          >
            <div class="grid gap-5 sm:grid-cols-2">
              <label class="block">
                <span class="text-xs uppercase tracking-[0.18em] text-mauve-700/70">Nom &amp; prénom</span>
                <input
                  type="text"
                  name="Nom"
                  required
                  class="mt-2 block w-full rounded-md border border-mauve-200 bg-cream-50 px-4 py-3 text-sm text-ink-900 placeholder-ink-700/40 focus:border-mauve-500 focus:outline-none focus:ring-2 focus:ring-mauve-200"
                />
              </label>

              <label class="block">
                <span class="text-xs uppercase tracking-[0.18em] text-mauve-700/70">Téléphone</span>
                <input
                  type="tel"
                  name="Telephone"
                  required
                  class="mt-2 block w-full rounded-md border border-mauve-200 bg-cream-50 px-4 py-3 text-sm text-ink-900 placeholder-ink-700/40 focus:border-mauve-500 focus:outline-none focus:ring-2 focus:ring-mauve-200"
                />
              </label>
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
              <label class="block">
                <span class="text-xs uppercase tracking-[0.18em] text-mauve-700/70">Email</span>
                <input
                  type="email"
                  name="Email"
                  required
                  class="mt-2 block w-full rounded-md border border-mauve-200 bg-cream-50 px-4 py-3 text-sm text-ink-900 placeholder-ink-700/40 focus:border-mauve-500 focus:outline-none focus:ring-2 focus:ring-mauve-200"
                />
              </label>

              <label class="block">
                <span class="text-xs uppercase tracking-[0.18em] text-mauve-700/70">Commune</span>
                <select
                  name="Commune"
                  class="mt-2 block w-full rounded-md border border-mauve-200 bg-cream-50 px-4 py-3 text-sm text-ink-900 focus:border-mauve-500 focus:outline-none focus:ring-2 focus:ring-mauve-200"
                >
                  <option value="">— Sélectionner —</option>
                  {ZONES.map((z) => <option value={z.name}>{z.name}{z.postalCode ? ` (${z.postalCode})` : ""}</option>)}
                  <option value="Autre">Autre commune</option>
                </select>
              </label>
            </div>

            <label class="block">
              <span class="text-xs uppercase tracking-[0.18em] text-mauve-700/70">Service souhaité</span>
              <select
                name="Service"
                class="mt-2 block w-full rounded-md border border-mauve-200 bg-cream-50 px-4 py-3 text-sm text-ink-900 focus:border-mauve-500 focus:outline-none focus:ring-2 focus:ring-mauve-200"
              >
                <option value="">— Sélectionner —</option>
                {SERVICES.map((s) => <option value={s.name}>{s.shortName}</option>)}
                <option value="Plusieurs">Plusieurs / je ne sais pas</option>
              </select>
            </label>

            <label class="block">
              <span class="text-xs uppercase tracking-[0.18em] text-mauve-700/70">Description du projet</span>
              <textarea
                name="Description"
                rows="6"
                required
                placeholder="Pièces concernées, surfaces estimées, état actuel, délais souhaités…"
                class="mt-2 block w-full rounded-md border border-mauve-200 bg-cream-50 px-4 py-3 text-sm text-ink-900 placeholder-ink-700/40 focus:border-mauve-500 focus:outline-none focus:ring-2 focus:ring-mauve-200"
              ></textarea>
            </label>

            <button
              type="submit"
              class="inline-flex items-center gap-2 rounded-full bg-mauve-500 px-7 py-4 text-sm font-medium text-cream-50 shadow-lg shadow-mauve-500/20 transition hover:bg-mauve-600"
            >
              Envoyer la demande
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-4 w-4">
                <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/>
                <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

            <p class="text-xs leading-relaxed text-ink-700/60">
              En envoyant ce formulaire, vous acceptez que Gary vous contacte pour préparer le devis.
              Vos données ne sont utilisées que pour cette demande. Voir la
              <a href="/politique-confidentialite" class="text-mauve-600 underline-offset-4 hover:underline">politique de confidentialité</a>.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ENGAGEMENT DEVIS -->
  <section class="crepi relative bg-cream-100 py-20 lg:py-24">
    <div class="mx-auto max-w-4xl px-6 text-center lg:px-10">
      <p class="text-xs uppercase tracking-[0.22em] text-mauve-600">Engagement</p>
      <h2 class="mt-6 font-display text-3xl leading-tight text-ink-900 sm:text-4xl">
        Devis gratuit · sur-mesure · <span class="script-gradient italic">étudié à la main</span>.
      </h2>
      <p class="mx-auto mt-8 max-w-2xl text-base leading-relaxed text-ink-700">
        Chaque devis est unique. Gary prend le temps d'évaluer chaque surface, chaque difficulté,
        chaque exigence — c'est ce qui permet d'aligner précisément le prix sur la prestation.
        Pas de devis express, pas de tarification à la louche.
      </p>
    </div>
  </section>
</BaseLayout>
