---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Devis from "../components/Devis.astro";
import { SITE } from "../data/site";
import angelot from "../assets/galerie/2025-03-01_(1).webp";
import rosaceBleue from "../assets/galerie/2025-03-01_(5).webp";
import miniRosace from "../assets/galerie/2025-03-01_(4).webp";
import ledCouloir from "../assets/galerie/2025-03-01.webp";
import ledGeometrique from "../assets/galerie/2025-03-01_(2).webp";
import cielPeint from "../assets/galerie/2025-03-01_(3).webp";

const seoTitle = "Réalisations — galerie";
const seoDesc =
  "Galerie des réalisations de Gary Goder : ornements en plâtre, décors peints, faux ciel, plafonds décoratifs. Chantiers en Lorraine.";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: SITE.url },
    { "@type": "ListItem", position: 2, name: "Réalisations", item: `${SITE.url}/realisations` },
  ],
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  url: `${SITE.url}/realisations`,
  name: seoTitle,
  description: seoDesc,
};

// TODO Gary : faire valider les descriptions exactes + ajouter de nouvelles photos quand dispo
const realisations = [
  {
    src: angelot,
    alt: "Angelot en plâtre sculpté",
    titre: "Angelot en plâtre",
    categorie: "Ornements",
    desc: "Pièce sculptée en plâtre, posée et raccordée à la main.",
  },
  {
    src: rosaceBleue,
    alt: "Grande rosace de plafond en plâtre",
    titre: "Grande rosace de plafond",
    categorie: "Ornements",
    desc: "Rosace décorative posée et mise en peinture au centre du plafond.",
  },
  {
    src: miniRosace,
    alt: "Rosace décorative en plâtre",
    titre: "Rosace décorative",
    categorie: "Ornements",
    desc: "Petite rosace en plâtre, idéale pour intégrer un point lumineux.",
  },
  {
    src: ledCouloir,
    alt: "Plafond décoratif éclairé",
    titre: "Plafond décoratif éclairé",
    categorie: "Plâtrerie décorative",
    desc: "Travail de plâtrerie avec éclairage intégré, finition peinture mate.",
  },
  {
    src: ledGeometrique,
    alt: "Plafond décoratif géométrique éclairé",
    titre: "Plafond géométrique",
    categorie: "Plâtrerie décorative",
    desc: "Composition géométrique en plâtre avec éclairage encastré.",
  },
  {
    src: cielPeint,
    alt: "Faux ciel peint à la main",
    titre: "Faux ciel peint à la main",
    categorie: "Décor d'art",
    desc: "Plafond peint en trompe-l'œil — l'une des quatre spécialités décoratives de Gary.",
  },
];
---

<BaseLayout title={seoTitle} description={seoDesc} extraSchemas={[collectionPageSchema, breadcrumbSchema]}>
  <!-- HERO -->
  <section class="relative isolate overflow-hidden bg-mauve-900 text-cream-50 pt-40 pb-24 lg:pt-48 lg:pb-32 grain">
    <div
      class="absolute inset-0 -z-10"
      style="background: radial-gradient(ellipse at 30% 40%, rgba(122,107,154,0.5), transparent 60%), radial-gradient(ellipse at 80% 70%, rgba(235,215,180,0.18), transparent 60%);"
    ></div>

    <div class="mx-auto max-w-7xl px-6 lg:px-10">
      <nav class="mb-10" aria-label="Fil d'Ariane">
        <ol class="flex flex-wrap items-center text-xs uppercase tracking-[0.22em] text-cream-100/60">
          <li><a href="/" class="hover:text-cream-50">Accueil</a></li>
          <li aria-hidden="true" class="mx-2">/</li>
          <li><span class="text-cream-100" aria-current="page">Réalisations</span></li>
        </ol>
      </nav>

      <p class="text-xs uppercase tracking-[0.22em] text-mauve-300">Galerie</p>
      <h1 class="mt-6 max-w-4xl font-display text-5xl leading-[1.05] sm:text-6xl lg:text-7xl">
        <span class="script-gradient italic text-[1.4em]">Réalisations</span>
        de Gary Goder.
      </h1>
      <p class="mt-10 max-w-2xl text-lg leading-relaxed text-cream-100/85">
        Ornements en plâtre, plafonds décoratifs, faux ciels peints à la main. Quelques chantiers récents en Lorraine — cliquez sur une image pour l'agrandir.
      </p>
    </div>
  </section>

  <!-- GALERIE -->
  <section class="crepi relative bg-cream-50 py-24 lg:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-10">
      <div class="grid gap-8 sm:grid-cols-2 lg:gap-10">
        {realisations.map((r, i) => (
          <figure class="group flex flex-col gap-5">
            <button
              type="button"
              class="realisation-trigger relative block overflow-hidden rounded-lg bg-mauve-100"
              data-index={i}
              aria-label={`Agrandir : ${r.titre}`}
            >
              <Image
                src={r.src}
                alt={r.alt}
                widths={[480, 720, 1080, 1440]}
                sizes="(min-width: 768px) 45vw, 100vw"
                class="block aspect-[4/3] h-full w-full object-cover transition duration-700 group-hover:scale-[1.03]"
              />
              <span class="pointer-events-none absolute inset-0 flex items-center justify-center bg-mauve-950/0 transition group-hover:bg-mauve-950/25">
                <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-cream-50/15 text-cream-50 opacity-0 ring-1 ring-cream-50/30 backdrop-blur transition group-hover:opacity-100">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-5 w-5">
                    <path d="M15 3h6v6M14 10l7-7M9 21H3v-6M10 14l-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </span>
            </button>

            <figcaption class="space-y-2">
              <p class="text-[11px] uppercase tracking-[0.22em] text-mauve-600">{r.categorie}</p>
              <h3 class="font-display text-2xl leading-tight text-ink-900">{r.titre}</h3>
              <p class="text-sm leading-relaxed text-ink-700/85">{r.desc}</p>
            </figcaption>
          </figure>
        ))}
      </div>

      <p class="mt-20 text-center text-sm italic text-ink-700/60">
        D'autres réalisations seront ajoutées au fil des chantiers.
      </p>
    </div>
  </section>

  <Devis />

  <!-- Lightbox -->
  <dialog
    id="realisation-lightbox"
    class="m-0 max-h-none max-w-none h-full w-full bg-transparent p-0 backdrop:bg-mauve-950/85 backdrop:backdrop-blur-sm"
  >
    <div class="relative flex h-full w-full items-center justify-center p-4 sm:p-8">
      <button
        type="button"
        data-lightbox-close
        class="absolute right-4 top-4 z-10 inline-flex h-11 w-11 items-center justify-center rounded-full bg-cream-50/10 text-cream-50 ring-1 ring-cream-50/25 backdrop-blur transition hover:bg-cream-50/20 sm:right-6 sm:top-6"
        aria-label="Fermer"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-5 w-5">
          <line x1="6" y1="6" x2="18" y2="18" stroke-linecap="round"/>
          <line x1="18" y1="6" x2="6" y2="18" stroke-linecap="round"/>
        </svg>
      </button>

      <button
        type="button"
        data-lightbox-prev
        class="absolute left-3 top-1/2 z-10 inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-cream-50/10 text-cream-50 ring-1 ring-cream-50/25 backdrop-blur transition hover:bg-cream-50/20 sm:left-6"
        aria-label="Précédent"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-5 w-5">
          <polyline points="15 6 9 12 15 18" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <button
        type="button"
        data-lightbox-next
        class="absolute right-3 top-1/2 z-10 inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-cream-50/10 text-cream-50 ring-1 ring-cream-50/25 backdrop-blur transition hover:bg-cream-50/20 sm:right-6"
        aria-label="Suivant"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-5 w-5">
          <polyline points="9 6 15 12 9 18" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <figure class="flex max-h-full max-w-6xl items-center justify-center">
        <img
          data-lightbox-img
          src=""
          alt=""
          class="max-h-[88vh] w-auto max-w-full rounded-lg object-contain shadow-2xl"
        />
      </figure>
    </div>
  </dialog>
</BaseLayout>

<script>
  const dialog = document.getElementById("realisation-lightbox") as HTMLDialogElement | null;
  if (dialog) {
    const triggers = Array.from(
      document.querySelectorAll<HTMLButtonElement>(".realisation-trigger")
    );
    const imgEl = dialog.querySelector<HTMLImageElement>("[data-lightbox-img]");
    const closeBtn = dialog.querySelector<HTMLButtonElement>("[data-lightbox-close]");
    const prevBtn = dialog.querySelector<HTMLButtonElement>("[data-lightbox-prev]");
    const nextBtn = dialog.querySelector<HTMLButtonElement>("[data-lightbox-next]");

    let current = 0;

    const photos = triggers.map((btn) => {
      const img = btn.querySelector("img");
      return {
        src: img?.currentSrc || img?.src || "",
        alt: img?.alt || "",
      };
    });

    const render = (i: number) => {
      const p = photos[i];
      if (!p || !imgEl) return;
      imgEl.src = p.src;
      imgEl.alt = p.alt;
      current = i;
    };

    const open = (i: number) => {
      render(i);
      dialog.showModal();
      document.body.style.overflow = "hidden";
    };

    const close = () => {
      dialog.close();
      document.body.style.overflow = "";
    };

    triggers.forEach((btn, i) => btn.addEventListener("click", () => open(i)));
    closeBtn?.addEventListener("click", close);
    prevBtn?.addEventListener("click", () => render((current - 1 + photos.length) % photos.length));
    nextBtn?.addEventListener("click", () => render((current + 1) % photos.length));

    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) close();
    });

    dialog.addEventListener("cancel", (e) => {
      e.preventDefault();
      close();
    });

    document.addEventListener("keydown", (e) => {
      if (!dialog.open) return;
      if (e.key === "ArrowLeft") render((current - 1 + photos.length) % photos.length);
      if (e.key === "ArrowRight") render((current + 1) % photos.length);
    });
  }
</script>
