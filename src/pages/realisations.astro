---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Devis from "../components/Devis.astro";
import { SITE } from "../data/site";
import heroRealisations from "../assets/realisations/moulure/moulure-03.webp";
import moulureOrnement from "../assets/realisations/moulure/moulure-09.webp";
import moulureCorniche from "../assets/realisations/moulure/moulure-16.webp";
import moulurePose from "../assets/realisations/moulure/moulure-14.webp";
import fauxCiel from "../assets/realisations/faux-ciel/faux-ciel-01.webp";
import betonCire from "../assets/realisations/beton-cire/beton-cire-01.webp";
import enduitDeco from "../assets/realisations/peinture-decorative/peinture-decorative-02.webp";
import enduitMural from "../assets/realisations/peinture-decorative/peinture-decorative-06.webp";
import peintureCombles from "../assets/realisations/peinture-interieure/peinture-interieure-09.webp";
import peintureTexturee from "../assets/realisations/peinture-interieure/peinture-interieure-10.webp";
import facadeTerminee from "../assets/realisations/peinture-exterieure/peinture-exterieure-21.webp";
import ravalementFacade from "../assets/realisations/peinture-exterieure/peinture-exterieure-19.webp";
import fresqueMurale from "../assets/realisations/peinture-decorative/peinture-decorative-01.webp";
import cuisineModerne from "../assets/realisations/peinture-decorative/peinture-decorative-03.webp";
import verriereAtelier from "../assets/realisations/renovation/renovation-05.webp";
import verriereGrosPlan from "../assets/realisations/renovation/renovation-06.webp";
import doucheBetonCire from "../assets/realisations/renovation/renovation-17.webp";
import murBetonCire from "../assets/realisations/renovation/renovation-14.webp";
import fauxPlafondLed from "../assets/realisations/moulure/moulure-05.webp";

const seoTitle = "Réalisations — galerie";
const seoDesc =
  "Galerie des réalisations de Gary Goder : moulures, faux ciel, béton ciré, verrières, fresques, enduits décoratifs, peinture intérieure et extérieure. Chantiers en Lorraine.";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: SITE.url },
    { "@type": "ListItem", position: 2, name: "Réalisations", item: `${SITE.url}/realisations` },
  ],
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  url: `${SITE.url}/realisations`,
  name: seoTitle,
  description: seoDesc,
};

const realisations = [
  {
    src: moulureOrnement,
    alt: "Ornement en plâtre sculpté — chérubin et corniche décorative",
    titre: "Chérubin et corniche ornée",
    categorie: "Moulures & ornements",
    desc: "Sculpture de chérubin posée dans un triangle de plafond, entourée de frises florales et d'une corniche en arc.",
  },
  {
    src: moulureCorniche,
    alt: "Corniche ornementale au plafond avec motifs floraux",
    titre: "Corniche ornementale",
    categorie: "Moulures & ornements",
    desc: "Angle de corniche en plâtre avec motifs de fruits et feuillages, posée et raccordée à la main.",
  },
  {
    src: fauxCiel,
    alt: "Faux ciel peint à la main — plafond de salle de bain",
    titre: "Faux ciel peint à la main",
    categorie: "Décor d'art",
    desc: "Plafond de salle de bain peint en trompe-l'œil — nuages et lumière dorée. Une des quatre spécialités décoratives de Gary.",
  },
  {
    src: fresqueMurale,
    alt: "Fresque murale décorative en noir et blanc",
    titre: "Fresque murale",
    categorie: "Peinture décorative",
    desc: "Portrait stylisé peint directement sur le mur, en noir et blanc, dans un intérieur contemporain.",
  },
  {
    src: betonCire,
    alt: "Sol en béton ciré dans une cuisine contemporaine",
    titre: "Béton ciré en cuisine",
    categorie: "Béton ciré",
    desc: "Sol en béton ciré coulé dans une cuisine ouverte contemporaine, finition lisse et lumineuse.",
  },
  {
    src: enduitDeco,
    alt: "Enduit décoratif texturé argenté sur mur en combles",
    titre: "Enduit décoratif texturé",
    categorie: "Peinture décorative",
    desc: "Mur de combles traité en enduit décoratif argenté avec effet de matière, sous pente avec velux.",
  },
  {
    src: enduitMural,
    alt: "Panneau mural en enduit décoratif gris dans un couloir",
    titre: "Panneau mural décoratif",
    categorie: "Peinture décorative",
    desc: "Panneau mural en enduit texturé, posé dans un couloir sur parquet chêne.",
  },
  {
    src: peintureCombles,
    alt: "Combles rénovés — peinture intérieure et poutres grises",
    titre: "Rénovation de combles",
    categorie: "Peinture intérieure",
    desc: "Pièce sous combles entièrement rénovée : poutres peintes en gris, murs blancs, sol posé.",
  },
  {
    src: peintureTexturee,
    alt: "Peinture décorative et papier peint dans une pièce rénovée",
    titre: "Peinture intérieure et papier peint",
    categorie: "Peinture intérieure",
    desc: "Combinaison de papier peint graphique et d'enduit décoratif sur mur adjacent, plafond lambris.",
  },
  {
    src: fauxPlafondLed,
    alt: "Faux-plafond moulé avec éclairage LED intégré dans un couloir",
    titre: "Faux-plafond moulé et LED",
    categorie: "Moulures & ornements",
    desc: "Couloir habillé d'un faux-plafond en plâtre mouluré avec éclairage LED indirect intégré dans les gorges.",
  },
  {
    src: moulurePose,
    alt: "Corniche en plâtre en cours de pose au plafond",
    titre: "Pose de corniche",
    categorie: "Moulures & ornements",
    desc: "Corniche classique en cours de pose — raccord précis des motifs à oves et rais-de-cœur.",
  },
  {
    src: verriereAtelier,
    alt: "Verrière style atelier posée dans un couloir blanc",
    titre: "Verrière style atelier",
    categorie: "Verrière",
    desc: "Verrière en acier noir posée dans un couloir d'appartement ancien, apportant lumière et caractère.",
  },
  {
    src: verriereGrosPlan,
    alt: "Verrière noire horizontale — gros plan sur les traverses",
    titre: "Verrière — détail des traverses",
    categorie: "Verrière",
    desc: "Gros plan sur une verrière horizontale à traverses noires, intégrée dans une cloison blanche avec moulures.",
  },
  {
    src: doucheBetonCire,
    alt: "Douche en béton ciré aux murs avec colonne de douche noire",
    titre: "Douche béton ciré",
    categorie: "Béton ciré",
    desc: "Cabine de douche entièrement revêtue de béton ciré aux murs, colonne de douche noire mate.",
  },
  {
    src: murBetonCire,
    alt: "Mur en béton ciré dans une cabine de douche — texture lisse",
    titre: "Béton ciré mural",
    categorie: "Béton ciré",
    desc: "Mur de douche en béton ciré, finition lisse et minérale, raccord sol en pierre naturelle.",
  },
  {
    src: cuisineModerne,
    alt: "Cuisine contemporaine noire avec plan de travail en bois",
    titre: "Cuisine contemporaine",
    categorie: "Rénovation complète",
    desc: "Cuisine entièrement rénovée : meubles noirs, plan de travail bois, sol béton ciré clair.",
  },
  {
    src: facadeTerminee,
    alt: "Façade terminée — peinture extérieure blanc et gris bleu",
    titre: "Façade rénovée",
    categorie: "Peinture extérieure",
    desc: "Ravalement complet d'une façade en bi-ton blanc et gris bleu, finition propre.",
  },
  {
    src: ravalementFacade,
    alt: "Ravalement de façade en cours — échafaudage et peinture bi-ton",
    titre: "Ravalement de façade",
    categorie: "Peinture extérieure",
    desc: "Façade de maison en cours de ravalement, traitement bi-ton avec échafaudage.",
  },
];
---

<BaseLayout title={seoTitle} description={seoDesc} extraSchemas={[collectionPageSchema, breadcrumbSchema]}>
  <!-- HERO -->
  <section class="relative isolate overflow-hidden bg-mauve-900 text-cream-50 pt-40 pb-24 lg:pt-48 lg:pb-32 grain">
    <Image
      src={heroRealisations}
      alt=""
      loading="eager"
      widths={[800, 1280, 1920]}
      sizes="100vw"
      class="hero-bg-img absolute inset-0 -z-20 h-full w-full object-cover object-center"
    />
    <div class="absolute inset-0 -z-10 hero-overlay-image"></div>

    <div class="mx-auto max-w-7xl px-6 lg:px-10">
      <nav class="mb-10" aria-label="Fil d'Ariane">
        <ol class="flex flex-wrap items-center text-xs uppercase tracking-[0.22em] text-cream-100/60">
          <li><a href="/" class="hover:text-cream-50">Accueil</a></li>
          <li aria-hidden="true" class="mx-2">/</li>
          <li><span class="text-cream-100" aria-current="page">Réalisations</span></li>
        </ol>
      </nav>

      <p class="text-xs uppercase tracking-[0.22em] text-mauve-300">Galerie</p>
      <h1 class="hero-readable mt-6 max-w-4xl font-display text-5xl leading-[1.05] sm:text-6xl lg:text-7xl">
        <span class="script-gradient italic text-[1.4em]">Réalisations</span>
        de Gary Goder.
      </h1>
      <p class="mt-10 max-w-2xl text-lg leading-relaxed text-cream-100/85">
        Moulures, faux ciel, béton ciré, verrières, fresques, enduits décoratifs, peinture intérieure et extérieure. Chantiers récents en Lorraine — cliquez sur une image pour l'agrandir.
      </p>
    </div>
  </section>

  <!-- GALERIE -->
  <section class="crepi relative bg-cream-50 py-24 lg:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-10">
      <div class="grid gap-8 sm:grid-cols-2 lg:gap-10">
        {realisations.map((r, i) => (
          <figure class="group flex flex-col gap-5">
            <button
              type="button"
              class="realisation-trigger relative block cursor-pointer overflow-hidden rounded-lg bg-mauve-100"
              data-index={i}
              aria-label={`Agrandir : ${r.titre}`}
            >
              <Image
                src={r.src}
                alt={r.alt}
                widths={[480, 720, 1080, 1440]}
                sizes="(min-width: 768px) 45vw, 100vw"
                class="block aspect-[4/3] h-full w-full object-cover transition duration-700 group-hover:scale-[1.03]"
              />
              <span class="pointer-events-none absolute inset-0 flex items-center justify-center bg-mauve-950/0 transition group-hover:bg-mauve-950/25">
                <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-cream-50/15 text-cream-50 opacity-0 ring-1 ring-cream-50/30 backdrop-blur transition group-hover:opacity-100">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-5 w-5">
                    <path d="M15 3h6v6M14 10l7-7M9 21H3v-6M10 14l-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </span>
            </button>

            <figcaption class="space-y-2">
              <p class="text-[11px] uppercase tracking-[0.22em] text-mauve-600">{r.categorie}</p>
              <h3 class="font-display text-2xl leading-tight text-ink-900">{r.titre}</h3>
              <p class="text-sm leading-relaxed text-ink-700/85">{r.desc}</p>
            </figcaption>
          </figure>
        ))}
      </div>

      <p class="mt-20 text-center text-sm italic text-ink-700/60">
        D'autres réalisations seront ajoutées au fil des chantiers.
      </p>
    </div>
  </section>

  <Devis />

  <!-- Lightbox -->
  <dialog
    id="realisation-lightbox"
    class="m-0 max-h-none max-w-none h-full w-full bg-transparent p-0 backdrop:bg-mauve-950/85 backdrop:backdrop-blur-sm"
  >
    <div class="relative flex h-full w-full items-center justify-center p-4 sm:p-8">
      <button
        type="button"
        data-lightbox-close
        class="absolute right-4 top-4 z-10 inline-flex h-11 w-11 items-center justify-center rounded-full bg-cream-50/10 text-cream-50 ring-1 ring-cream-50/25 backdrop-blur transition hover:bg-cream-50/20 sm:right-6 sm:top-6"
        aria-label="Fermer"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-5 w-5">
          <line x1="6" y1="6" x2="18" y2="18" stroke-linecap="round"/>
          <line x1="18" y1="6" x2="6" y2="18" stroke-linecap="round"/>
        </svg>
      </button>

      <button
        type="button"
        data-lightbox-prev
        class="absolute left-3 top-1/2 z-10 inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-cream-50/10 text-cream-50 ring-1 ring-cream-50/25 backdrop-blur transition hover:bg-cream-50/20 sm:left-6"
        aria-label="Précédent"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-5 w-5">
          <polyline points="15 6 9 12 15 18" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <button
        type="button"
        data-lightbox-next
        class="absolute right-3 top-1/2 z-10 inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-cream-50/10 text-cream-50 ring-1 ring-cream-50/25 backdrop-blur transition hover:bg-cream-50/20 sm:right-6"
        aria-label="Suivant"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-5 w-5">
          <polyline points="9 6 15 12 9 18" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <figure class="flex max-h-full max-w-6xl items-center justify-center">
        <img
          data-lightbox-img
          src=""
          alt=""
          class="max-h-[88vh] w-auto max-w-full rounded-lg object-contain shadow-2xl"
        />
      </figure>
    </div>
  </dialog>
</BaseLayout>

<script>
  const dialog = document.getElementById("realisation-lightbox") as HTMLDialogElement | null;
  if (dialog) {
    const triggers = Array.from(
      document.querySelectorAll<HTMLButtonElement>(".realisation-trigger")
    );
    const imgEl = dialog.querySelector<HTMLImageElement>("[data-lightbox-img]");
    const closeBtn = dialog.querySelector<HTMLButtonElement>("[data-lightbox-close]");
    const prevBtn = dialog.querySelector<HTMLButtonElement>("[data-lightbox-prev]");
    const nextBtn = dialog.querySelector<HTMLButtonElement>("[data-lightbox-next]");

    let current = 0;
    let savedScrollY = 0;

    const photos = triggers.map((btn) => {
      const img = btn.querySelector("img");
      return {
        src: img?.currentSrc || img?.src || "",
        alt: img?.alt || "",
      };
    });

    const render = (i: number) => {
      const p = photos[i];
      if (!p || !imgEl) return;
      imgEl.src = p.src;
      imgEl.alt = p.alt;
      current = i;
    };

    const open = (i: number) => {
      render(i);
      savedScrollY = window.scrollY;
      document.documentElement.style.scrollBehavior = "auto";
      dialog.showModal();
      document.body.style.overflow = "hidden";
      window.scrollTo(0, savedScrollY);
      document.documentElement.style.scrollBehavior = "";
    };

    const close = () => {
      dialog.close();
      document.body.style.overflow = "";
      document.documentElement.style.scrollBehavior = "auto";
      window.scrollTo(0, savedScrollY);
      document.documentElement.style.scrollBehavior = "";
    };

    triggers.forEach((btn, i) => btn.addEventListener("click", () => open(i)));
    closeBtn?.addEventListener("click", close);
    prevBtn?.addEventListener("click", () => render((current - 1 + photos.length) % photos.length));
    nextBtn?.addEventListener("click", () => render((current + 1) % photos.length));

    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) close();
    });

    dialog.addEventListener("cancel", (e) => {
      e.preventDefault();
      close();
    });

    document.addEventListener("keydown", (e) => {
      if (!dialog.open) return;
      if (e.key === "ArrowLeft") render((current - 1 + photos.length) % photos.length);
      if (e.key === "ArrowRight") render((current + 1) % photos.length);
    });
  }
</script>
