---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../data/site";
---

<BaseLayout
  title="Politique de confidentialité"
  description="Comment KGM Pro Decor traite vos données personnelles."
  noindex={true}
  lightHeader={false}
>
  <section class="bg-cream-50 pt-40 pb-24 lg:pt-48 lg:pb-32">
    <div class="mx-auto max-w-3xl px-6 lg:px-10">
      <p class="text-xs uppercase tracking-[0.22em] text-mauve-600">Confidentialité</p>
      <h1 class="mt-6 font-display text-4xl leading-tight text-ink-900 sm:text-5xl">
        Politique de <span class="script text-6xl text-mauve-500">confidentialité</span>.
      </h1>

      <div class="mt-12 space-y-10 text-base leading-relaxed text-ink-700">
        <div>
          <h2 class="font-display text-2xl text-ink-900">Données collectées</h2>
          <p class="mt-3">
            Ce site ne collecte aucune donnée personnelle de manière automatique. Les seules
            informations recueillies sont celles que vous fournissez explicitement par téléphone
            ou par email lors d'une demande de devis : nom, coordonnées, description du projet.
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl text-ink-900">Utilisation</h2>
          <p class="mt-3">
            Vos informations servent uniquement à établir un devis et à exécuter la prestation.
            Elles ne sont jamais transmises à des tiers, ni utilisées à des fins commerciales.
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl text-ink-900">Cookies</h2>
          <p class="mt-3">
            Ce site n'utilise pas de cookies de suivi. Aucun outil analytique tiers n'est installé
            par défaut.
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl text-ink-900">Vos droits (RGPD)</h2>
          <p class="mt-3">
            Vous disposez d'un droit d'accès, de rectification et de suppression de vos données.
            Pour exercer ces droits, contactez-nous à <a href={`mailto:${SITE.email}`} class="text-mauve-600 underline-offset-4 hover:underline">{SITE.email}</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
